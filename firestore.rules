rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // CRITICAL GLOBAL SECURE ACCESS HELPERS (Phase 3 Primitives)
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // VALIDATION ENTITY HELPER FUNCTIONS (Eight Pillars)
    // -------------------------------------------------------------------------

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'currentStreakDays', 'dailyGoalMinutes'])
        && data.keys().size() == 6
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.displayName.size() >= 1
        && data.photoURL is string && data.photoURL.size() <= 1024
        && data.currentStreakDays is int
        && data.currentStreakDays >= 0
        && data.dailyGoalMinutes is int
        && data.dailyGoalMinutes >= 0;
    }

    // Cart contains array of items and updatedAt timestamp
    function isValidCart(data) {
      return data.keys().hasAll(['items', 'updatedAt'])
        && data.keys().size() == 2
        && data.items is list
        && data.items.size() <= 100
        && data.updatedAt is string && data.updatedAt.size() <= 128;
    }

    // Wishlist contains array of books and updatedAt timestamp
    function isValidWishlist(data) {
      return data.keys().hasAll(['books', 'updatedAt'])
        && data.keys().size() == 2
        && data.books is list
        && data.books.size() <= 200
        && data.updatedAt is string && data.updatedAt.size() <= 128;
    }

    // Progress tracks user reading journals
    function isValidProgress(data) {
      return data.keys().hasAll(['history', 'updatedAt'])
        && data.keys().size() == 2
        && data.history is list
        && data.history.size() <= 100
        && data.updatedAt is string && data.updatedAt.size() <= 128;
    }

    // Book Reviews tracks reader reviews
    function isValidBookReviews(data) {
      return data.keys().hasAll(['reviews'])
        && data.keys().size() == 1
        && data.reviews is list
        && data.reviews.size() <= 1000;
    }

    // -------------------------------------------------------------------------
    // SERVICE MATCH BLOCKS FOR ALL ACTIVE COLLECTION PATHS (Phase 4 rules)
    // -------------------------------------------------------------------------

    // Users Collection
    match /users/{userId} {
      allow get: if isVerifiedUser() && isOwner(userId);
      allow create: if isVerifiedUser() && isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isVerifiedUser() && isOwner(userId) && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email;
      allow delete: if false; // Users cannot self-delete profiles
    }

    // Carts Collection
    match /carts/{userId} {
      allow get: if isVerifiedUser() && isOwner(userId);
      allow create: if isVerifiedUser() && isOwner(userId) && isValidCart(incoming());
      allow update: if isVerifiedUser() && isOwner(userId) && isValidCart(incoming());
      allow delete: if isVerifiedUser() && isOwner(userId);
    }

    // Wishlists Collection
    match /wishlists/{userId} {
      allow get: if isVerifiedUser() && isOwner(userId);
      allow create: if isVerifiedUser() && isOwner(userId) && isValidWishlist(incoming());
      allow update: if isVerifiedUser() && isOwner(userId) && isValidWishlist(incoming());
      allow delete: if isVerifiedUser() && isOwner(userId);
    }

    // Progress Collection
    match /progress/{userId} {
      allow get: if isVerifiedUser() && isOwner(userId);
      allow create: if isVerifiedUser() && isOwner(userId) && isValidProgress(incoming());
      allow update: if isVerifiedUser() && isOwner(userId) && isValidProgress(incoming());
      allow delete: if isVerifiedUser() && isOwner(userId);
    }

    // Book Reviews Collection (Public Reading, Verified Writing)
    match /reviews/{bookId} {
      allow get: if isSignedIn(); // Any authenticated reader can get reviews
      allow create: if isVerifiedUser() && isValidId(bookId) && isValidBookReviews(incoming());
      allow update: if isVerifiedUser() && isValidId(bookId) && isValidBookReviews(incoming());
      allow delete: if false; // Reviews cannot be deleted via Client SDK
    }
  }
}
